<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<?import javafx.scene.shape.SVGPath?>
<VBox alignment="CENTER" id="MainLayout" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      stylesheets="@css/signup.css" fx:controller="com.mazenfahim.YallaBudget.SignUpController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <VBox id="signupForm">

        <!-- Title -->
        <Label text="Create Account" id="titleLabel" />
        <Label text="Sign up to start managing your budget" id="subtitleLabel" />

        <!-- Fields -->
        <TextField fx:id="usernameField" promptText="Enter your username" styleClass="field"/>
        <TextField fx:id="emailField" promptText="Enter your email" styleClass="field"/>

        <!-- Password with toggle -->
        <StackPane alignment="CENTER_RIGHT" styleClass="passwordBox" maxWidth="Infinity">
            <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="field" maxWidth="Infinity"/>
            <TextField fx:id="passwordVisible" promptText="Enter your password" styleClass="field" maxWidth="Infinity" visible="false" managed="false"/>
            <Button onAction="#togglePasswordVisibility"
                    pickOnBounds="false"
                    styleClass="eye-button"
                    StackPane.alignment="CENTER_RIGHT">
                <graphic>
                    <SVGPath content="M12 5C7 5 2.73 8.11 1 12c1.73 3.89 6 7 11 7s9.27-3.11 11-7c-1.73-3.89-6-7-11-7zm0 11a4 4 0 1 1 0-8 4 4 0 0 1 0 8z"
                             styleClass="eye-icon"/>
                </graphic>
            </Button>
        </StackPane>

        <!-- Confirm Password with toggle -->
        <StackPane alignment="CENTER_RIGHT" styleClass="passwordBox" maxWidth="Infinity">
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" styleClass="field" maxWidth="Infinity"/>
            <TextField fx:id="confirmPasswordVisible" promptText="Confirm your password" styleClass="field" maxWidth="Infinity" visible="false" managed="false"/>
            <Button onAction="#toggleConfirmVisibility"
                    pickOnBounds="false"
                    styleClass="eye-button"
                    StackPane.alignment="CENTER_RIGHT">
                <graphic>
                    <SVGPath content="M12 5C7 5 2.73 8.11 1 12c1.73 3.89 6 7 11 7s9.27-3.11 11-7c-1.73-3.89-6-7-11-7zm0 11a4 4 0 1 1 0-8 4 4 0 0 1 0 8z"
                             styleClass="eye-icon"/>
                </graphic>
            </Button>
        </StackPane>

        <!-- Sign Up Button -->
        <Button fx:id="signUpButton" id="signUpButton" text="Create Account" onAction="#storeCredentials"/>

        <!-- Divider -->
        <HBox alignment="CENTER" spacing="10" id="dividerBox">
            <Region HBox.hgrow="ALWAYS" id="dividerLine"/>
            <Label text="or" id="dividerLabel"/>
            <Region HBox.hgrow="ALWAYS" id="dividerLine"/>
        </HBox>

        <!-- Login link -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="Already have an account?" id="loginPrompt"/>
            <Hyperlink fx:id="loginLink" id="loginLink" text="Log in" onAction="#goToLogin"/>
        </HBox>

    </VBox>
</VBox>